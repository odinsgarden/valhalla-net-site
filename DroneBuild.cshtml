/* VALHALLA'S 13TH INNOVATIONS UNIT: MISSION-READY UI */
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;900&family=JetBrains+Mono:wght@400;700&display=swap');

:root {
  --neon-green: #00FF41;   /* Tactical HUD Green */
  --obsidian: #020202;     /* Absolute Black */
  --panel-hex: rgba(0, 255, 65, 0.03);
  --v-border: rgba(0, 255, 65, 0.3);
}

body {
  background-color: var(--obsidian) !important;
  color: #FFFFFF !important;
  font-family: 'JetBrains Mono', monospace !important;
  background-image: 
    linear-gradient(var(--v-border) 1px, transparent 1px),
    linear-gradient(90deg, var(--v-border) 1px, transparent 1px);
  background-size: 45px 45px;
  background-attachment: fixed;
}

.tactical-card {
  background: rgba(5, 5, 5, 0.9) !important;
  border: 1px solid var(--v-border) !important;
  border-left: 4px solid var(--neon-green) !important;
  padding: 40px;
  margin: 30px 0;
  position: relative;
  box-shadow: 0 0 50px rgba(0, 0, 0, 1);
}

h1, h2, h3 {
  font-family: 'Orbitron', sans-serif !important;
  color: var(--neon-green) !important;
  letter-spacing: 5px;
  text-transform: uppercase;
  text-shadow: 0 0 15px rgba(0, 255, 65, 0.4);
}

/* THE COMMAND BUTTON */
.btn-dispatch {
  background: var(--neon-green) !important;
  color: #000 !important;
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  padding: 18px 45px;
  text-decoration: none;
  display: inline-block;
  clip-path: polygon(10% 0, 100% 0, 90% 100%, 0% 100%);
  border: none;
  transition: 0.3s;
  letter-spacing: 2px;
  margin-top: 20px;
}

.btn-dispatch:hover {
  transform: scale(1.05);
  box-shadow: 0 0 25px var(--neon-green);
  filter: brightness(1.2);
}

.hr-table {
  width: 100%;
  border-collapse: collapse;
  margin: 20px 0;
}

.hr-table td {
  padding: 15px;
  border-bottom: 1px solid #111;
  color: #888;
}

.hr-table td strong { color: var(--neon-green); }
